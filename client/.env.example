# Front Bug Bounty — Next.js (UI + API demos)
#
# Copier ce fichier en `.env.local` pour le dev local (prioritaire sur `.env`).
# Ne jamais committer de secrets : `.env*` est ignoré sauf ce fichier d’exemple.

# ---------------------------------------------------------------------------
# URLs du site (SEO, Open Graph, liens absolus)
# En prod : URL publique du front (ex. Vercel).
# En local : aligné sur `pnpm dev` → port 3001 (Nest API sur 3000 par défaut dans ce monorepo).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# NEXT_PUBLIC_SITE_URL=https://bugbountyapp.vercel.app

# Origine Nest (login/register JWT). Aligner avec GLOBAL_PREFIX si besoin (défaut côté serveur : `api`).
NEXT_PUBLIC_AUTH_API=http://localhost:3000
# NEXT_PUBLIC_AUTH_API_PREFIX=api

# Même valeur que JWT_SECRET du serveur Nest — vérifie le JWT côté Next (DAL / POST /api/session).
# Obligatoire pour cookie httpOnly d’accès et protection Server Components.
JWT_SECRET=

# ---------------------------------------------------------------------------
# Emails transactionnels (Resend) — route POST /api/send
# Clé API : https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxx

# ---------------------------------------------------------------------------
# Facultatif — Node
# Next.js définit souvent NODE_ENV tout seul ; rarement besoin de le fixer en local.
# NODE_ENV=development
