# Front Bug Bounty — Next.js + Prisma (client)
#
# Copier ce fichier en `.env.local` pour le dev local (prioritaire sur `.env`).
# Ne jamais committer de secrets : `.env*` est ignoré sauf ce fichier d’exemple.

# ---------------------------------------------------------------------------
# URLs du site (SEO, Open Graph, liens absolus)
# En prod : URL publique du front (ex. Vercel).
# En local : aligné sur `pnpm dev` → port 3001 (le 3000 reste pour l’API Nest dans ce monorepo).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Prod VPS (baked in at `pnpm build` — rebuild after change):
# NEXT_PUBLIC_SITE_URL=https://hackthebounty.fr
# NEXT_PUBLIC_AUTH_API=https://api.hackthebounty.fr
NEXT_PUBLIC_AUTH_API=http://localhost:3000
NEXT_PUBLIC_AUTH_API_PREFIX=api

# -------------- JWT 
JWT_SECRET=mon-lapin-caillousky-dans-la-serre

# ---------------------------------------------------------------------------
# Session — renouvellement silencieux du JWT d’accès (keep-alive navigateur)
# Doit rester STRICTEMENT inférieur à JWT_EXPIRES_IN côté Nest (`server/.env`, ex. 15m).
# Ex. access 15m → mettre 12m ici pour rafraîchir avant expiration.
# Format : suffixe ms|s|m|h|d (comme JWT_EXPIRES_IN) ou entier en millisecondes via *_MS.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SESSION_REFRESH_INTERVAL=12m
# NEXT_PUBLIC_SESSION_REFRESH_INTERVAL_MS=720000

# ---------------------------------------------------------------------------
# Prisma (client — futur / optionnel ; l’API Nest porte le schéma principal)
# Valeurs : sqlite | postgresql | mysql
# ---------------------------------------------------------------------------
DATABASE_PROVIDER=sqlite

# URL de connexion Prisma
# SQLite (défaut) : fichier sous client/prisma/
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL :
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bugbountyapp
# MySQL (aligné sur server avec DATABASE_NAME=MYSQL_PRISMA) :
# DATABASE_PROVIDER=mysql
# DATABASE_URL=mysql://bugbountyapp:bugbountyapp@localhost:3306/bugbountyapp


# ---------------------------------------------------------------------------
# BFF — rate limiting (Next middleware, @upstash/ratelimit)
# Requiert une base Redis exposée en REST (Upstash Console → REST API).
# Pas le même format que REDIS_URL (redis://) du serveur Nest : créer une DB Upstash
# ou un proxy REST vers votre Redis local (voir doc Upstash « developing locally »).
# Si les variables ci-dessous sont absentes, le middleware /api/* ne limite pas (warning en prod).
# ---------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Désactivé automatiquement si NODE_ENV=development ou test. Forcer en local : BFF_RATE_LIMIT_FORCE=1.
# BFF_RATE_LIMIT_DISABLED=1
# BFF_RATE_LIMIT_TRUST_PROXY=1
# Plafond global /api (par IP + politique) :
BFF_RATE_LIMIT_DEFAULT=100
BFF_RATE_LIMIT_WINDOW=1m
# POST /api/session (établissement cookie après login Nest) :
# BFF_RATE_LIMIT_SESSION=30
# BFF_RATE_LIMIT_SESSION_WINDOW=15m
# Step-up mot de passe (aligné sur Nest routeHitLimits) :
# BFF_RATE_LIMIT_PROFILE_VERIFY=10
# BFF_RATE_LIMIT_PROFILE_VERIFY_WINDOW=15m
# BFF_RATE_LIMIT_ACCOUNT_VERIFY=5
# BFF_RATE_LIMIT_ACCOUNT_VERIFY_WINDOW=15m
# POST /api/account/register-user :
# BFF_RATE_LIMIT_REGISTER=5
# BFF_RATE_LIMIT_REGISTER_WINDOW=15m

# ---------------------------------------------------------------------------
# IP access (whitelist) — configuré côté API Nest, pas ici
# Bandeau admin « IP_ACCESS_FORCE=1 » : ajouter dans server/.env pour activer
# la whitelist en dev (désactivée par défaut si NODE_ENV=development).
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Facultatif — Node
# Next.js définit souvent NODE_ENV tout seul ; rarement besoin de le fixer en local.
# NODE_ENV=development

