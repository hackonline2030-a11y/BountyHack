<!doctype html>
<html lang="<%= data.htmlLang || 'fr' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= data.fullName || 'CV' %></title>
    <link rel="stylesheet" href="<%= data.templateStylesheetUrl %>" />
  </head>
  <body>
    <%
      const profileImage = data.profileImage;
      const labels = data.labels || {};
      const leftColumn = data.leftColumn || {};
      const portfolio = leftColumn.portfolio || {};
      const rightColumn = data.rightColumn || {};
      const experiences = rightColumn.experiences || [];
      const formations = rightColumn.formations || [];
      const previousExperiences = rightColumn.previousExperiences || [];
      const bulletStyleAttr = data.bulletsColor ? ` style="--bullet-color: ${data.bulletsColor};"` : '';
    %>
    <div class="cv bullet-style-<%= data.bulletStyle || 'dot' %>">
      <section class="top-section section">
        <div class="top-photo">
          <div class="profile-top">
            <div class="profile-bg"></div>
            <div class="profile-photo-wrap">
              <img class="profile-photo" src="<%= profileImage %>" alt="<%= labels.profilePhotoAlt || '' %>" />
            </div>
          </div>
        </div>
        <div class="top-content">
          <div class="header-grid">
            <div class="header-main">
              <h1 class="name"><%= data.fullName || labels.placeholderFullName %></h1>
              <p class="title"><%= data.jobTitle || labels.placeholderJobTitle %></p>
            </div>
            <div class="header-contact">
              <% (leftColumn.contact || []).slice(0, 3).forEach(function(line) { %>
                <p><%= line %></p>
              <% }); %>
            </div>
          </div>
          <div class="intro summary-block">
            <% (data.summary || '').split('\n').filter(Boolean).forEach(function(paragraph) { %>
              <p><%= paragraph %></p>
            <% }); %>
          </div>
        </div>
      </section>

      <div class="layout">
        <aside class="left">
          <% if (portfolio.url) { %>
            <section class="section portfolio-section">
              <a class="portfolio-link" href="<%= portfolio.url %>" target="_blank" rel="noreferrer">
                <svg class="icon icon-globe" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"></circle>
                  <ellipse cx="12" cy="12" rx="4.5" ry="9" fill="none" stroke="currentColor" stroke-width="1.5"></ellipse>
                  <path d="M3 12h18M5 7.5h14M5 16.5h14" fill="none" stroke="currentColor" stroke-width="1.5"></path>
                </svg>
                <span><%= portfolio.label || labels.portfolioFallback %></span>
                <svg class="icon icon-link" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M10 14l4-4M8 16H6a4 4 0 010-8h4M16 8h2a4 4 0 010 8h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                </svg>
              </a>
            </section>
          <% } %>

          <section class="section">
            <% (leftColumn.skills || []).forEach(function(skill) { %>
              <div class="small-block">
                <p class="label"><%= skill.title %></p>
                <% (skill.items || []).forEach(function(item) { %>
                  <p class="line"><%= item %></p>
                <% }); %>
              </div>
            <% }); %>
          </section>

          <section class="section">
            <h2 class="section-title"><%= labels.languages %></h2>
            <% (leftColumn.languages || []).forEach(function(line) { %>
              <p class="line"><%= line %></p>
            <% }); %>
          </section>

          <section class="section">
            <h2 class="section-title"><%= labels.interests %></h2>
            <% (leftColumn.interests || []).forEach(function(line) { %>
              <p class="line"><%= line %></p>
            <% }); %>
          </section>
        </aside>

        <main class="right">
          <section class="section">
            <h2 class="section-title"><%= labels.experience %></h2>
            <% experiences.forEach(function(exp) { %>
              <article class="small-block">
                <h3 class="item-title"><%= exp.title %></h3>
                <p class="item-meta">
                  <%= exp.period || '' %>
                  <% if (exp.company) { %>
                    <span> | </span>
                    <% if (exp.companyLink) { %>
                      <a class="inline-link" href="<%= exp.companyLink %>" target="_blank" rel="noreferrer">
                        <span><%= exp.company %></span>
                        <svg class="icon icon-link" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M10 14l4-4M8 16H6a4 4 0 010-8h4M16 8h2a4 4 0 010 8h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                        </svg>
                      </a>
                    <% } else { %>
                      <span><%= exp.company %></span>
                    <% } %>
                  <% } %>
                </p>
                <% if (exp.intro) { %>
                  <p class="item-text"><%= exp.intro %></p>
                <% } %>
                <% if ((exp.items || []).length) { %>
                  <ul class="bullet-list"<%- bulletStyleAttr %>>
                    <% (exp.items || []).forEach(function(item) { %>
                      <li class="item-text"><%= item %></li>
                    <% }); %>
                  </ul>
                <% } %>
              </article>
            <% }); %>
          </section>

          <section class="section">
            <h2 class="section-title"><%= labels.education %></h2>
            <% formations.forEach(function(edu) { %>
              <article class="small-block">
                <h3 class="item-title"><%= edu.degreeName %></h3>
                <p class="item-meta">
                  <%= edu.period || '' %>
                  <% if (edu.school) { %>
                    <span> | </span>
                    <% if (edu.degreeLink) { %>
                      <a class="inline-link" href="<%= edu.degreeLink %>" target="_blank" rel="noreferrer">
                        <span><%= edu.school %></span>
                        <svg class="icon icon-link" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M10 14l4-4M8 16H6a4 4 0 010-8h4M16 8h2a4 4 0 010 8h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                        </svg>
                      </a>
                    <% } else { %>
                      <span><%= edu.school %></span>
                    <% } %>
                  <% } %>
                </p>
                <% if (edu.intro) { %>
                  <p class="item-text"><%= edu.intro %></p>
                <% } %>
                <% if ((edu.items || []).length) { %>
                  <ul class="bullet-list"<%- bulletStyleAttr %>>
                    <% (edu.items || []).forEach(function(eduItem) { %>
                      <li class="item-text"><%= eduItem %></li>
                    <% }); %>
                  </ul>
                <% } %>
              </article>
            <% }); %>
          </section>

          <section class="section">
            <h2 class="section-title"><%= labels.previousExperience %></h2>
            <% previousExperiences.forEach(function(item) { %>
              <article class="small-block">
                <h3 class="item-title"><%= item.title %></h3>
                <p class="item-meta">
                  <%= item.period || '' %>
                  <% if (item.company) { %>
                    <span> | </span>
                    <% if (item.companyLink) { %>
                      <a class="inline-link" href="<%= item.companyLink %>" target="_blank" rel="noreferrer">
                        <span><%= item.company %></span>
                        <svg class="icon icon-link" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M10 14l4-4M8 16H6a4 4 0 010-8h4M16 8h2a4 4 0 010 8h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                        </svg>
                      </a>
                    <% } else { %>
                      <span><%= item.company %></span>
                    <% } %>
                  <% } %>
                </p>
                <% if (item.intro) { %>
                  <p class="item-text"><%= item.intro %></p>
                <% } %>
                <% if ((item.items || []).length) { %>
                  <ul class="bullet-list"<%- bulletStyleAttr %>>
                    <% (item.items || []).forEach(function(summaryItem) { %>
                      <li class="item-text"><%= summaryItem %></li>
                    <% }); %>
                  </ul>
                <% } %>
              </article>
            <% }); %>
          </section>
        </main>
      </div>
    </div>
  </body>
</html>