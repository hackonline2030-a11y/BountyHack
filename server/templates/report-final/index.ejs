<!doctype html>
<html lang="<%= data.htmlLang || 'fr' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= data.title || data.labels.reportTitle %></title>
    <link rel="stylesheet" href="<%= data.templateStylesheetUrl %>" />
  </head>
  <body>
    <%
      const labels = data.labels || {};
      const meta = data.meta || {};
      const cvss = data.cvss || {};
      const sections = Array.isArray(data.sections) ? data.sections : [];
      const team = data.reportTeam;

      const escapeHtml = (s) =>
        String(s ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');

      const markdownToHtml = (value) => {
        const source = String(value || '')
          .replace(/\\n/g, '\n')
          .replace(/```([\s\S]*?)```/g, (_m, code) =>
            `<pre class="code-block code-block--light">${escapeHtml(code)}</pre>`,
          )
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/^###\s+(.+)$/gm, '<h4>$1</h4>')
          .replace(/^##\s+(.+)$/gm, '<h3>$1</h3>')
          .replace(/^-\s+(.+)$/gm, '<li>$1</li>')
          .replace(/(?:^|\n)(\d+)\.\s+(.+)/g, (_m, n, txt) => `\n<li value="${n}">${txt}</li>`);

        const withLists = source.replace(/(<li[\s\S]*?<\/li>\n?)+/g, (list) => {
          const hasValues = /value="\d+"/.test(list);
          return hasValues ? `<ol>${list}</ol>` : `<ul>${list}</ul>`;
        });

        return withLists
          .split(/\n{2,}/)
          .map((item) => item.trim())
          .filter(Boolean)
          .map((item) => {
            if (/^<(h3|h4|ul|ol|pre)/.test(item) || /<\/(ul|ol|pre)>$/.test(item)) {
              return item;
            }
            return `<p>${item.replace(/\n/g, '<br/>')}</p>`;
          })
          .join('\n');
      };

      const renderSectionBloc = (bloc) => {
        const heading = String(bloc.heading || '').trim();
        const subheading = String(bloc.subheading || '').trim();
        const body = String(bloc.body || '').trim();
        let html = '';
        if (heading) html += `<h3>${escapeHtml(heading)}</h3>`;
        if (subheading) html += `<h4>${escapeHtml(subheading)}</h4>`;
        if (body) html += markdownToHtml(body);
        const lists = Array.isArray(bloc.lists) ? bloc.lists : [];
        lists.forEach((list) => {
          const items = Array.isArray(list && list.items) ? list.items : [];
          if (!items.length) return;
          const tag = list && list.ordered ? 'ol' : 'ul';
          html += `<${tag}>${items.map((it) => `<li>${escapeHtml(it)}</li>`).join('')}</${tag}>`;
        });
        return html;
      };
    %>

    <div class="report-page">
      <section class="cover-page page-frame">
        <p class="cover-meta"><%= labels.reportTitle %></p>
        <h1 class="cover-title"><%= escapeHtml(data.title) %></h1>
        <% if (team && team.label) { %>
          <p class="cover-author"><%= escapeHtml(team.label) %></p>
        <% } %>
        <p class="cover-meta">
          ID <%= escapeHtml(data.reportId) %><br />
          <%= data.frozenAt ? new Date(data.frozenAt).toLocaleString(data.language || 'fr') : '' %>
        </p>
      </section>

      <section class="card section-card page-frame">
        <h2><%= labels.metaSectionTitle %></h2>
        <div class="fiche-grid">
          <div class="fiche-field fiche-field--full">
            <span class="fiche-label"><%= labels.fieldReportTitle %></span>
            <span class="fiche-value"><%= escapeHtml(meta.reportTitle) %></span>
          </div>
          <div class="fiche-field">
            <span class="fiche-label"><%= labels.fieldScope %></span>
            <span class="fiche-value"><%= escapeHtml(meta.scopeSlug) %></span>
          </div>
          <div class="fiche-field">
            <span class="fiche-label"><%= labels.fieldBugType %></span>
            <span class="fiche-value"><%= escapeHtml(meta.bugType) %></span>
          </div>
          <div class="fiche-field fiche-field--full">
            <span class="fiche-label"><%= labels.fieldEndpoint %></span>
            <span class="fiche-value"><code class="kbd"><%= escapeHtml(meta.endpoint) %></code></span>
          </div>
          <div class="fiche-field">
            <span class="fiche-label"><%= labels.fieldCve %></span>
            <span class="fiche-value"><%= escapeHtml(meta.cve) %></span>
          </div>
          <div class="fiche-field">
            <span class="fiche-label"><%= labels.fieldImpact %></span>
            <span class="fiche-value"><%= escapeHtml(meta.impact) %></span>
          </div>
          <% if (meta.technicalEnvironment) { %>
            <div class="fiche-field fiche-field--full">
              <span class="fiche-label">Environnement technique</span>
              <span class="fiche-value"><%= escapeHtml(meta.technicalEnvironment) %></span>
            </div>
          <% } %>
          <% if (meta.applicationFingerprint) { %>
            <div class="fiche-field fiche-field--full">
              <span class="fiche-label">Empreinte application</span>
              <span class="fiche-value"><%= escapeHtml(meta.applicationFingerprint) %></span>
            </div>
          <% } %>
        </div>
      </section>

      <% if (Object.keys(cvss).length) { %>
        <section class="card section-card page-frame section-card--page-break">
          <h2><%= labels.cvssSectionTitle %></h2>
          <div class="fiche-grid">
            <% [
              ['attackVector', 'Vecteur d’attaque'],
              ['attackComplexity', 'Complexité'],
              ['privilegesRequired', 'Privilèges requis'],
              ['userInteraction', 'Interaction utilisateur'],
              ['scope', 'Scope'],
              ['confidentiality', 'Confidentialité'],
              ['integrity', 'Intégrité'],
              ['availability', 'Disponibilité'],
            ].forEach(function (pair) {
              const key = pair[0];
              const label = pair[1];
              if (cvss[key] === undefined || cvss[key] === null || cvss[key] === '') return;
            %>
              <div class="fiche-field">
                <span class="fiche-label"><%= label %></span>
                <span class="fiche-value"><%= escapeHtml(cvss[key]) %></span>
              </div>
            <% }); %>
          </div>
        </section>
      <% } %>

      <% if (team && Array.isArray(team.members) && team.members.length) { %>
        <section class="card section-card page-frame">
          <h2><%= labels.teamSectionTitle %></h2>
          <ul class="team-list">
            <% team.members.forEach(function (member) { %>
              <li>
                <strong><%= escapeHtml(member.displayName) %></strong>
                — <%= escapeHtml(member.role) %>
              </li>
            <% }); %>
          </ul>
        </section>
      <% } %>

      <% sections.forEach(function (section) { %>
        <section
          class="card section-card page-frame section-card--page-break"
          id="section-<%= escapeHtml(section.key) %>"
        >
          <h2><%= escapeHtml(section.title) %></h2>
          <div class="markdown-body">
            <% if (!section.sectionBlocs || !section.sectionBlocs.length) { %>
              <p class="fiche-muted">—</p>
            <% } else { %>
              <% section.sectionBlocs.forEach(function (bloc) { %>
                <article class="section-bloc">
                  <%- renderSectionBloc(bloc) %>
                </article>
              <% }); %>
            <% } %>
          </div>
        </section>
      <% }); %>
    </div>
  </body>
</html>
