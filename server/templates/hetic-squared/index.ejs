<!doctype html>
<html lang="<%= data.htmlLang || 'fr' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= data.fullName || 'CV' %></title>
    <link rel="stylesheet" href="<%= data.templateStylesheetUrl %>" />
  </head>
  <body>
    <%
      const headings = data.headings || {};
      const hp = headings.profile || 'Profil';
      const hc = headings.contact || 'Coordonnées';
      const hskills = headings.competencies || 'Compétences';
      const hlang = headings.language || 'Langue';
      const hobbies = headings.activities || 'Activités et loisirs';
      const hproj = headings.projects || 'Mes projets';

      const profileImage = data.profileImage || '';
      const labels = data.labels || {};
      const leftColumn = data.leftColumn || {};
      const portfolio = leftColumn.portfolio || {};
      const rightColumn = data.rightColumn || {};
      const experiences = rightColumn.experiences || [];
      const formations = rightColumn.formations || [];
      const previousExperiences = rightColumn.previousExperiences || [];
      const projects = rightColumn.projects || [];
      const githubFooter = rightColumn.githubFooter;
      const profileLinks = data.profileLinks || [];
      const contactRows = data.contactRows || [];
      const bulletStyleAttr = data.bulletsColor ? ` style="--bullet-color: ${data.bulletsColor};"` : '';
    %>
    <div class="cv bullet-style-<%= data.bulletStyle || 'dot' %>">
      <header class="hetic-banner">
        <div class="hetic-banner-copy">
          <h1 class="name"><%= data.fullName || labels.placeholderFullName %></h1>
          <p class="job-banner"><%= data.jobTitle || labels.placeholderJobTitle %></p>
        </div>
        <div class="hetic-photo-block">
          <div class="hetic-photo-accent" aria-hidden="true"></div>
          <div class="hetic-photo-wrap">
            <img class="hetic-photo-img" src="<%= profileImage %>" alt="<%= labels.profilePhotoAlt || '' %>" />
          </div>
        </div>
      </header>

      <div class="hetic-columns">
        <aside class="left hetic-sidebar">
          <section class="hetic-block">
            <div class="hetic-block-heading">
              <h2 class="hetic-heading"><%= hp %></h2>
              <% if (profileLinks.length) { %>
                <nav class="hetic-profile-links" aria-label="<%= hp %>">
                  <% profileLinks.forEach(function (link) { %>
                    <% const isLd = /^linkedin/i.test(link.label || ''); %>
                    <a class="hetic-profile-chip" href="<%= link.url %>" target="_blank" rel="noreferrer noopener" title="<%= link.label %>">
                      <% if (isLd) { %>
                        <svg class="hetic-profile-icon" viewBox="0 0 24 24" aria-hidden="true">
                          <path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                        </svg>
                      <% } else { %>
                        <svg class="hetic-profile-icon" viewBox="0 0 24 24" aria-hidden="true">
                          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M9 17H7a5 5 0 010-10h2M17 17h2a5 5 0 000-10h-2M8 12h8"></path>
                        </svg>
                      <% } %>
                      <span class="sr-only"><%= link.label %></span>
                    </a>
                  <% }); %>
                </nav>
              <% } else if (portfolio.url) { %>
                <nav class="hetic-profile-links" aria-label="<%= portfolio.label %>">
                  <a class="hetic-profile-chip" href="<%= portfolio.url %>" target="_blank" rel="noreferrer noopener">
                    <svg class="hetic-profile-icon" viewBox="0 0 24 24" aria-hidden="true">
                      <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"></circle>
                      <ellipse cx="12" cy="12" rx="4.5" ry="9" fill="none" stroke="currentColor" stroke-width="1.5"></ellipse>
                      <path d="M3 12h18M5 7.5h14M5 16.5h14" fill="none" stroke="currentColor" stroke-width="1.5"></path>
                    </svg>
                  </a>
                </nav>
              <% } %>
            </div>
            <hr class="hetic-rule" />
            <div class="hetic-prose summary-block">
              <% (data.summary || '').split('\n').filter(Boolean).forEach(function (paragraph) { %>
                <p><%= paragraph %></p>
              <% }); %>
            </div>
          </section>

          <section class="hetic-block">
            <h2 class="hetic-heading"><%= hc %></h2>
            <hr class="hetic-rule" />
            <% contactRows.forEach(function (row) { %>
              <% const iconKind = row.icon || 'mail'; %>
              <p class="hetic-contact-row">
                <% if (iconKind === 'phone') { %>
                  <span class="hetic-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M5 4h4l2 4-3 3a12 12 0 0 0 6 6l3-3 4 2v4l-6 4H9"></path>
                    </svg>
                  </span>
                <% } else if (iconKind === 'map') { %>
                  <span class="hetic-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path fill="none" stroke="currentColor" stroke-width="2" d="M4 11l9-8 9 8v11H4zm9-5v22"></path>
                    </svg>
                  </span>
                <% } else { %>
                  <span class="hetic-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path fill="none" stroke="currentColor" stroke-width="2" d="M3 9l9-6 9 6v13H3zm0 11h18"></path>
                    </svg>
                  </span>
                <% } %>
                <span class="hetic-contact-text"><%= row.text %></span>
              </p>
            <% }); %>
          </section>

          <section class="hetic-block">
            <h2 class="hetic-heading"><%= hskills %></h2>
            <hr class="hetic-rule" />
            <% (leftColumn.skills || []).forEach(function (skill) { %>
              <div class="skill-group">
                <p class="skill-group-label"><%= skill.title %></p>
                <% (skill.items || []).forEach(function (item) { %>
                  <p class="line"><%= item %></p>
                <% }); %>
              </div>
            <% }); %>
          </section>

          <section class="hetic-block">
            <h2 class="hetic-heading"><%= hlang %></h2>
            <hr class="hetic-rule" />
            <% (leftColumn.languages || []).forEach(function (line, idx) { %>
              <% if (idx === 0) { %>
                <p class="line lang-lead"><%= line %></p>
              <% } else { %>
                <p class="line lang-detail"><%= line %></p>
              <% } %>
            <% }); %>
          </section>

          <section class="hetic-block">
            <h2 class="hetic-heading"><%= hobbies %></h2>
            <hr class="hetic-rule" />
            <ul class="bullet-list bullet-list-soft"<%- bulletStyleAttr %>>
              <% (leftColumn.interests || []).forEach(function (line) { %>
                <li class="item-text"><%= line %></li>
              <% }); %>
            </ul>
          </section>
        </aside>

        <main class="right hetic-main">
          <% if (projects.length) { %>
            <section class="hetic-block">
              <h2 class="hetic-heading-main"><%= hproj %></h2>
              <hr class="hetic-rule-main" />
              <% projects.forEach(function (proj) { %>
                <article class="proj-item">
                  <h3 class="proj-title-row">
                    <svg class="proj-link-ico" viewBox="0 0 24 24" aria-hidden="true">
                      <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.73 1.72M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 1 0 7.07 7.07l1.72-1.72"></path>
                    </svg>
                    <%= proj.title %>
                  </h3>
                  <% (proj.lines || []).forEach(function (lr) {
                       const ld = lr.lead ? lr.lead + ' : ' : '';
                  %>
                    <p class="proj-body"><span class="proj-lead"><%= ld %></span><%= lr.body %></p>
                  <% }); %>
                </article>
              <% }); %>
              <% if (githubFooter && githubFooter.text) { %>
                <p class="github-foot">
                  <% if (githubFooter.url) { %>
                    <a class="github-link" href="<%= githubFooter.url %>" target="_blank" rel="noreferrer noopener">
                      <svg class="proj-link-ico" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="currentColor" d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.26.8-.58v-2c-3.39.73-4.11-1.47-4.11-1.47-.55-1.39-1.35-1.76-1.35-1.76-1.1-.74.09-.73.09-.73 1.22.09 1.86 1.25 1.86 1.25 1.08 1.85 2.83 1.32 3.52 1 .11-.79.43-1.32.79-1.62-2.71-.31-5.56-1.37-5.56-6.07a4.75 4.75 0 0 1 1.26-3.31 4.43 4.43 0 0 1 .12-3.26s1-.33 3.39 1.26a11.71 11.71 0 0 1 6.15 0c2.39-1.59 3.39-1.26 3.39-1.26a4.43 4.43 0 0 1 .12 3.26 4.73 4.73 0 0 1 1.29 3.29c0 4.72-2.87 5.74-5.62 6.06.44.38.82 1.15.82 2.35v3.52c0 .41.26.71.82.58A12 12 0 0 0 12 .5"></path>
                      </svg>
                      <%= githubFooter.text %>
                    </a>
                  <% } else { %>
                    <%= githubFooter.text %>
                  <% } %>
                </p>
              <% } %>
            </section>
          <% } %>

          <% if (formations.length) { %>
            <section class="hetic-block">
              <h2 class="hetic-heading-main"><%= labels.education %></h2>
              <hr class="hetic-rule-main" />
              <% formations.forEach(function (edu) { %>
                <article class="edu-block">
                  <h3 class="item-title"><%= edu.degreeName %></h3>
                  <p class="item-meta hetic-muted-meta">
                    <%= edu.period || '' %>
                    <% if (edu.school) { %>
                      <% if (edu.period) { %><span> | </span><% } %>
                      <% if (edu.degreeLink) { %>
                        <a class="inline-link" href="<%= edu.degreeLink %>" target="_blank" rel="noreferrer noopener">
                          <%= edu.school %>
                        </a>
                      <% } else { %>
                        <span><%= edu.school %></span>
                      <% } %>
                    <% } %>
                  </p>
                  <% if (edu.intro) { %>
                    <p class="item-text"><%= edu.intro %></p>
                  <% } %>
                  <% if ((edu.items || []).length) { %>
                    <ul class="bullet-list"<%- bulletStyleAttr %>>
                      <% (edu.items || []).forEach(function (eduItem) { %>
                        <li class="item-text"><%= eduItem %></li>
                      <% }); %>
                    </ul>
                  <% } %>
                </article>
              <% }); %>
            </section>
          <% } %>

          <% if (experiences.length) { %>
            <section class="hetic-block">
              <h2 class="hetic-heading-main"><%= labels.experience %></h2>
              <hr class="hetic-rule-main" />
              <% experiences.forEach(function (exp) { %>
                <article class="edu-block">
                  <h3 class="item-title"><%= exp.title %></h3>
                  <p class="item-meta hetic-muted-meta">
                    <%= exp.period || '' %>
                    <% if (exp.company) { %>
                      <% if (exp.period) { %><span> | </span><% } %>
                      <% if (exp.companyLink) { %>
                        <a class="inline-link" href="<%= exp.companyLink %>" target="_blank" rel="noreferrer noopener">
                          <%= exp.company %>
                        </a>
                      <% } else { %>
                        <span><%= exp.company %></span>
                      <% } %>
                    <% } %>
                  </p>
                  <% if (exp.intro) { %>
                    <p class="item-text"><%= exp.intro %></p>
                  <% } %>
                  <% if ((exp.items || []).length) { %>
                    <ul class="bullet-list"<%- bulletStyleAttr %>>
                      <% (exp.items || []).forEach(function (item) { %>
                        <li class="item-text"><%= item %></li>
                      <% }); %>
                    </ul>
                  <% } %>
                </article>
              <% }); %>
            </section>
          <% } %>

          <% if (previousExperiences.length) { %>
            <section class="hetic-block">
              <h2 class="hetic-heading-main"><%= labels.previousExperience %></h2>
              <hr class="hetic-rule-main" />
              <% previousExperiences.forEach(function (item) { %>
                <article class="edu-block">
                  <h3 class="item-title"><%= item.title %></h3>
                  <p class="item-meta hetic-muted-meta">
                    <%= item.period || '' %>
                    <% if (item.company) { %>
                      <% if (item.period) { %><span> | </span><% } %>
                      <% if (item.companyLink) { %>
                        <a class="inline-link" href="<%= item.companyLink %>" target="_blank" rel="noreferrer noopener">
                          <%= item.company %>
                        </a>
                      <% } else { %>
                        <span><%= item.company %></span>
                      <% } %>
                    <% } %>
                  </p>
                  <% if (item.intro) { %>
                    <p class="item-text"><%= item.intro %></p>
                  <% } %>
                  <% if ((item.items || []).length) { %>
                    <ul class="bullet-list"<%- bulletStyleAttr %>>
                      <% (item.items || []).forEach(function (summaryItem) { %>
                        <li class="item-text"><%= summaryItem %></li>
                      <% }); %>
                    </ul>
                  <% } %>
                </article>
              <% }); %>
            </section>
          <% } %>
        </main>
      </div>
    </div>
  </body>
</html>
