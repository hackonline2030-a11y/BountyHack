{
  "name": "@web-api/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve",
    "build": "nx build",
    "test": "nx run web-api:test --verbose",
    "test:e2e": "nx run e2e:e2e",
    "test:all": "nx run-many -t test --projects web-api,e2e",
    "docker:up": "bash docker/start.sh up",
    "docker:watch": "bash docker/start.sh watch-up",
    "docker:stop": "bash docker/start.sh stop",
    "docker:watch-stop": "bash docker/start.sh watch-stop",
    "docker:down": "bash docker/start.sh down",
    "docker:down:volumes": "bash docker/start.sh down -v",
    "docker:seed-pg": "bash docker/start.sh dump-users-pg",
    "docker:exec:watch": "docker compose -f docker/compose.dev.yaml --profile watch --profile pg exec -it web-api-watch sh",
    "docker:prisma:deploy": "docker compose -f docker/compose.dev.yaml --profile watch --profile pg exec web-api-watch sh -lc \"cd /usr/src/app && pnpm exec prisma migrate deploy\"",
    "docker:prisma:migrate:dev": "docker compose -f docker/compose.dev.yaml --profile watch --profile pg exec -it web-api-watch sh -lc \"cd /usr/src/app && pnpm exec prisma migrate dev\"",
    "docker:prisma:generate": "docker compose -f docker/compose.dev.yaml --profile watch --profile pg exec web-api-watch sh -lc \"cd /usr/src/app && pnpm exec prisma generate\"",
    "docker:prisma:seed-demo": "docker compose -f docker/compose.dev.yaml --profile watch --profile pg exec web-api-watch sh -lc \"cd /usr/src/app && pnpm exec prisma db execute --file prisma/migrations/20260205120100_seed_demo_user/migration.sql\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed-demo": "prisma db execute --file prisma/migrations/20260205120100_seed_demo_user/migration.sql",
    "prisma:migrate:deploy:docker": "node docker/prisma-migrate-docker-from-host.cjs",
    "prisma:seed-demo:docker": "node docker/prisma-seed-demo-docker-from-host.cjs"
  },
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "axios": "^1.7.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.10.1",
    "nestjs-firebase": "^11.0.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.3",
    "puppeteer": "^24.42.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "uuid": "^9.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.19",
    "@nx/eslint": "20.3.2",
    "@nx/eslint-plugin": "20.3.2",
    "@nx/jest": "20.3.2",
    "@nx/js": "20.3.2",
    "@nx/nest": "20.3.2",
    "@nx/node": "20.3.2",
    "@nx/web": "20.3.2",
    "@nx/webpack": "20.3.2",
    "@nx/workspace": "20.3.2",
    "@swc-node/register": "~1.9.2",
    "@swc/core": "~1.5.29",
    "@swc/helpers": "~0.5.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "~18.16.20",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nx": "20.7.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "10.9.1",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.24.1",
    "webpack-cli": "^5.1.4"
  },
