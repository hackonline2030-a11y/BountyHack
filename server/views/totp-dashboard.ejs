<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Enable TOTP</title>
  <style>
    :root {
      --accent: #6d28d9;
      --accent-ring: rgba(109, 40, 217, 0.3);
      --line: #e4e4e9;
      --muted: #5c5c66;
    }
    body {
      font-family: system-ui, sans-serif;
      max-width: 32rem;
      margin: 2rem auto;
      padding: 0 1rem;
      line-height: 1.45;
    }
    h1 { font-size: 1.2rem; margin-top: 0; }
    p.hint { font-size: 0.85rem; color: var(--muted); }
    label { display: block; font-weight: 600; font-size: 0.8rem; margin-top: 0.75rem; }
    input[type="email"], input[type="password"], textarea {
      width: 100%;
      margin-top: 0.25rem;
      padding: 0.45rem 0.55rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      font-size: 0.95rem;
      box-sizing: border-box;
    }
    textarea { min-height: 4rem; font-family: monospace; font-size: 0.72rem; }
    input:focus, textarea:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-ring);
    }
    button {
      margin-top: 0.85rem;
      margin-right: 0.5rem;
      padding: 0.55rem 0.9rem;
      border-radius: 8px;
      border: none;
      background: var(--accent);
      color: #fff;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.88rem;
    }
    button.secondary { background: #fff; color: var(--accent); border: 1px solid var(--accent); }
    section {
      margin-top: 1.75rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--line);
    }
    .card {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 1rem 1.15rem;
      margin-top: 1rem;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .otp-row { display: flex; gap: 0.45rem; justify-content: space-between; margin: 0.75rem 0; }
    .otp-digit {
      width: 100%;
      max-width: 2.4rem;
      aspect-ratio: 1;
      text-align: center;
      font-size: 1rem;
      font-weight: 600;
      border: 1px solid var(--line);
      border-radius: 8px;
    }
    .otp-digit:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-ring);
    }
    #qr { display: block; max-width: 200px; margin: 0.5rem auto; }
    pre.uri { font-size: 0.65rem; word-break: break-all; background: #f4f4f6; padding: 0.6rem; border-radius: 8px; }
    .log { font-size: 0.78rem; white-space: pre-wrap; word-break: break-word; margin-top: 0.5rem; color: var(--muted); }
    .log.ok { color: #15803d; }
  </style>
</head>
<body>
<h1>Activer le TOTP (JWT)</h1>
<p class="hint">Flux production : <code>POST <%= apiPrefix %>/auth/totp/enable/start</code> puis <code>…/enable/confirm</code> avec en-tête <code>Authorization: Bearer &lt;JWT&gt;</code>. Nécessite <code>TOTP_ENCRYPTION_KEY</code> (≥ 16 car.) et <code>DATABASE_NAME=POSTGRESQL_PRISMA</code>. Issuer affiché dans l’app : <strong><%= issuer %></strong>.</p>

<section>
  <h2 style="font-size:1rem;">1 — Obtenir un JWT</h2>
  <form id="loginForm">
    <label for="email">Email</label>
    <input id="email" type="email" autocomplete="username" required />
    <label for="password">Mot de passe</label>
    <input id="password" type="password" autocomplete="current-password" required />
    <button type="submit">POST <%= apiPrefix %>/auth/login</button>
  </form>
  <label for="jwt">JWT (Bearer)</label>
  <textarea id="jwt" placeholder="Collez le token après login…"></textarea>
</section>

<section>
  <h2 style="font-size:1rem;">2 — Enable TOTP</h2>
  <button type="button" id="btnStart">Démarrer l’enrollment (start)</button>
  <div id="startLog" class="log"></div>

  <div id="enrollCard" class="card" style="display:none;">
    <p class="hint" style="margin-top:0;">Scannez le QR dans Google Authenticator (ou équivalent).</p>
    <img id="qr" alt="" />
    <details style="margin-top:0.75rem;">
      <summary style="cursor:pointer;color:var(--accent);font-size:0.9rem;">Saisie manuelle (secret / URI)</summary>
      <p class="hint" style="margin:0.35rem 0 0.2rem;">Secret Base32</p>
      <pre class="uri" id="secretOut"></pre>
      <p class="hint" style="margin:0.5rem 0 0.2rem;">otpauth URI</p>
      <pre class="uri" id="uriOut"></pre>
    </details>
    <p class="hint" style="margin-top:1rem;">Entrez le code à 6 chiffres affiché dans l’application.</p>
    <div class="otp-row" id="otpConfirm"></div>
    <button type="button" id="btnConfirm">Confirmer (enable/confirm)</button>
    <div id="confirmLog" class="log"></div>
  </div>
</section>

<script>
(function () {
  var apiPrefix = <%- JSON.stringify(apiPrefix) %>;
  var loginUrl = apiPrefix + '/auth/login';
  var startUrl = apiPrefix + '/auth/totp/enable/start';
  var confirmUrl = apiPrefix + '/auth/totp/enable/confirm';

  function buildOtpRow(containerId) {
    var row = document.getElementById(containerId);
    row.innerHTML = '';
    for (var i = 0; i < 6; i++) {
      var inp = document.createElement('input');
      inp.type = 'text';
      inp.inputMode = 'numeric';
      inp.maxLength = 1;
      inp.className = 'otp-digit';
      row.appendChild(inp);
    }
    var inputs = row.querySelectorAll('.otp-digit');
    inputs.forEach(function (input, idx) {
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Backspace' && !input.value && idx > 0) {
          inputs[idx - 1].focus();
        }
      });
      input.addEventListener('input', function () {
        var v = input.value.replace(/\D/g, '');
        input.value = v.slice(-1);
        if (input.value && idx < 5) inputs[idx + 1].focus();
      });
      input.addEventListener('paste', function (e) {
        e.preventDefault();
        var t = (e.clipboardData || window.clipboardData).getData('text') || '';
        var only = t.replace(/\D/g, '').slice(0, 6);
        for (var j = 0; j < 6; j++) inputs[j].value = only[j] || '';
        inputs[Math.min(only.length, 5)].focus();
      });
    });
  }

  function getOtpCode() {
    return Array.from(document.querySelectorAll('#otpConfirm .otp-digit')).map(function (el) {
      return el.value.replace(/\D/g, '');
    }).join('');
  }

  function bearerHeaders() {
    var t = document.getElementById('jwt').value.trim();
    return {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + t,
    };
  }

  buildOtpRow('otpConfirm');

  document.getElementById('loginForm').addEventListener('submit', async function (e) {
    e.preventDefault();
    var log = document.getElementById('startLog');
    log.textContent = '';
    try {
      var res = await fetch(loginUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: document.getElementById('email').value.trim(),
          password: document.getElementById('password').value,
        }),
      });
      var data = await res.json().catch(function () { return {}; });
      if (data.token) {
        document.getElementById('jwt').value = data.token;
        log.textContent = 'JWT reçu.';
        log.classList.add('ok');
      } else {
        log.textContent = res.status + '\n' + JSON.stringify(data, null, 2);
        log.classList.remove('ok');
      }
    } catch (err) {
      document.getElementById('startLog').textContent = String(err.message || err);
    }
  });

  document.getElementById('btnStart').addEventListener('click', async function () {
    var log = document.getElementById('startLog');
    log.classList.remove('ok');
    log.textContent = 'Requête…';
    document.getElementById('enrollCard').style.display = 'none';
    try {
      var res = await fetch(startUrl, {
        method: 'POST',
        headers: bearerHeaders(),
      });
      var data = await res.json().catch(function () { return {}; });
      if (!res.ok) {
        log.textContent = res.status + '\n' + JSON.stringify(data, null, 2);
        return;
      }
      log.textContent = 'Enrollment démarré — scannez le QR.';
      log.classList.add('ok');
      document.getElementById('enrollCard').style.display = 'block';
      document.getElementById('qr').src = data.secretQrCode || '';
      document.getElementById('secretOut').textContent = data.secret || '';
      document.getElementById('uriOut').textContent = data.otpauthUri || '';
      document.querySelector('#otpConfirm .otp-digit').focus();
    } catch (err) {
      log.textContent = String(err.message || err);
    }
  });

  document.getElementById('btnConfirm').addEventListener('click', async function () {
    var log = document.getElementById('confirmLog');
    log.classList.remove('ok');
    var code = getOtpCode();
    if (code.length !== 6) {
      log.textContent = 'Saisissez 6 chiffres.';
      return;
    }
    try {
      var res = await fetch(confirmUrl, {
        method: 'POST',
        headers: bearerHeaders(),
        body: JSON.stringify({ code: code }),
      });
      var data = await res.json().catch(function () { return {}; });
      log.textContent = res.status + '\n' + JSON.stringify(data, null, 2);
      if (res.ok && data.ok) log.classList.add('ok');
    } catch (err) {
      log.textContent = String(err.message || err);
    }
  });
})();
</script>
</body>
</html>
