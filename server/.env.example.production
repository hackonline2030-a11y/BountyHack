# =============================================================================
# API Bug Bounty — PRODUCTION (VPS LWS, PM2, MySQL/MariaDB, nginx)
# Copier vers server/.env sur le VPS ; remplacer uniquement les <secrets>.
# JWT_SECRET identique dans client/.env (lu au pnpm build). Guide : vps.md
# =============================================================================

NODE_ENV=production

# --- MySQL (Prisma — migrations-mysql/, schema.mysql.prisma) ---
DATABASE_NAME=MYSQL_PRISMA
DATABASE_URL=mysql://bugbountyapp:<mot-de-passe>@127.0.0.1:3306/bugbountyapp?allowPublicKeyRetrieval=true
SEED_DEMO_USER=false

# --- HTTP (nginx → 127.0.0.1:3000) ---
PORT=3000
GLOBAL_PREFIX=api
CORS_ORIGIN=https://hackthebounty.fr,https://www.hackthebounty.fr

# --- Auth JWT (Passport) — openssl rand -hex 32 ---
AUTH_TYPE=PASSPORT_JWT
JWT_SECRET=<secret-jwt>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- TOTP (2FA) — openssl rand -hex 32, stable par environnement ---
TOTP_ISSUER=BugBountyApp
TOTP_EPOCH_TOLERANCE=30
TOTP_ENCRYPTION_KEY=<secret-totp>

# --- Front (liens e-mail invitation / setup compte) ---
CLIENT_PUBLIC_BASE_URL=https://hackthebounty.fr
ACCOUNT_SETUP_TOKEN_TTL=48h
ALLOW_FAKE_USER_REGISTRATION=0

# --- E-mail (SMTP LWS) ---
MAIL_PROVIDER=smtp
MAIL_FROM_EMAIL=noreply@hackthebounty.fr
MAIL_FROM_NAME=BugBountyApp
SMTP_HOST=mail.hackthebounty.fr
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@hackthebounty.fr
SMTP_PASSWORD=<secret-smtp>
SMTP_REJECT_UNAUTHORIZED=true

# --- Redis (rate limit + BullMQ PDF) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# --- PDF (Chromium système : apt install chromium) ---
IS_PUPETTEER_WITH_CHROMIUM=false
CHROMIUM_PATH=/usr/bin/chromium

# --- Rate limiting (actif car NODE_ENV=production) ---
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_LOGIN=1
RATE_LIMIT_LOGIN_WINDOW=24h
RATE_LIMIT_REFRESH=30
RATE_LIMIT_REFRESH_WINDOW=15m
RATE_LIMIT_PASSWORD_RESET_CONFIRM=10
RATE_LIMIT_PASSWORD_RESET_CONFIRM_WINDOW=15m
RATE_LIMIT_PROFILE_VERIFY_PASSWORD=10
RATE_LIMIT_PROFILE_VERIFY_PASSWORD_WINDOW=15m
RATE_LIMIT_ACCOUNT_VERIFY_PASSWORD=5
RATE_LIMIT_ACCOUNT_VERIFY_PASSWORD_WINDOW=15m
RATE_LIMIT_TRUST_PROXY=1

# --- IP whitelist (actif en prod ; activer via /administration/ip-access) ---
# Si mode whitelist-only : ajouter 127.0.0.1/32 (trafic Next BFF → Nest sur le même VPS).
# IP_ACCESS_DISABLED=1
IP_ACCESS_WHITELIST_CACHE_TTL_SEC=30
