// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// Authenticator-app TOTP (`APP`) per https://medium.com/@a_zeraibi/designing-two-factor-authentication-that-scales-a2f78fab65e4
/// Add enum values and a dedicated credential table when introducing passkeys / WebAuthn.
enum TwoFactorMethod {
  APP
}

/// Postgres `users` table (Prisma + optional raw DDL bootstrap in `PrismaService`).
model User {
  id           String  @id
  username     String
  email        String? @unique
  passwordHash String? @map("password_hash")
  /// Global 2FA flag (e.g. 0 = off, non-zero = required / enabled); keep in sync with `two_factor` rows in app code.
  twoFactorEnabled BigInt @default(0) @map("two_factor_enabled")
  /// Optional RBAC role (`roles.id`). Nullable for existing rows until backfill.
  roleId       Int?    @map("role_id")

  twoFactors TwoFactor[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  role       Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  reportDraftsOwned       ReportDraft[] @relation("ReportDraftOwner")
  reportDraftsAsHunterWriter ReportDraft[] @relation("ReportDraftHunterWriter")
  reportTeamMembers ReportTeamMember[]
  reportTeamJoinRequests ReportTeamJoinRequest[] @relation("JoinRequestUser")
  reportTeamJoinRequestsDecided ReportTeamJoinRequest[] @relation("JoinRequestDecider")
  reportTeamLeaveRequests ReportTeamLeaveRequest[] @relation("LeaveRequestUser")
  reportTeamLeaveRequestsDecided ReportTeamLeaveRequest[] @relation("LeaveRequestDecider")
  qualityCriteriaCreated            QualityCriterion[]             @relation("QualityCriterionCreator")
  qualityCriterionDistributions     QualityCriterionDistribution[] @relation("QualityDistributionCreator")
  qualityCriterionChecks            QualityCriterionCheck[]        @relation("QualityCheckUpdater")

  @@index([roleId])
  @@map("users")
}

/// Application role (e.g. SUPER_ADMIN, HUNTER).
model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

/// RBAC target type (e.g. user, report, project). Table `objects` in ERD; Prisma model name avoids `Object` clash.
model AuthzObject {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  permissions Permission[]

  @@map("objects")
}

/// Atomic capability: `action` on an `AuthzObject` (e.g. read + user).
model Permission {
  id        Int         @id @default(autoincrement())
  action    String
  objectId  Int         @map("object_id")
  object    AuthzObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@index([objectId])
  @@map("permissions")
}

/// Many-to-many: which permissions each role receives.
model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Opaque refresh tokens (peer of Mongo `refresh_tokens` collection). Raw token is hashed at rest (`token_hash`).
model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique @map("token_hash")
  userId     String   @map("user_id")
  expiresAt  DateTime @map("expires_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// One-time opaque password reset (raw token only in email; `token_hash` = SHA-256 hex at rest).
model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Which 2FA methods exist for a user (source of truth per enabled method).
model TwoFactor {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  method    TwoFactorMethod
  verified  Boolean         @default(false)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  totp TwoFactorTotp?

  @@unique([userId, method])
  @@index([userId])
  @@map("two_factor")
}

/// TOTP-specific secret storage (encrypt at rest in application code, see article).
model TwoFactorTotp {
  id          String   @id @default(uuid())
  twoFactorId String   @unique @map("two_factor_id")
  secret      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  twoFactor TwoFactor @relation(fields: [twoFactorId], references: [id], onDelete: Cascade)

  @@map("two_factor_totp")
}

// ─── Report draft workflow (MCD v1 — hunter↔QC first; mentor / super-admin later) ───

enum DraftStep {
  META
  DESCRIPTION
  COLLECTION
  EXPLOITATION
  PROOF_OF_CONCEPT
  RISKS
  REMEDIATION
  FINAL
}

enum StepStatus {
  IN_PROGRESS
  AWAITING_REVIEW
  NEEDS_REVISION
  APPROVED
  IN_GLOBAL_PROGRESS
  NEEDS_GLOBAL_REVISION
  AWAITING_GLOBAL_REVIEW
}

enum ReportDraftAggregateStatus {
  DRAFT
  UNDER_REVIEW
  UNDER_GLOBAL_REVIEW
  READY_TO_PROGRAM
  SUBMITTED_TO_PROGRAM
  PUBLISHED
  GIVEN_UP
  REJECTED
}

enum ReviewerRole {
  HUNTER
  MENTOR
  QUALITY_CHECKER
  SUPER_ADMIN
}

enum SubmissionKind {
  HUNTER_TO_REVIEWER
  HUNTER_TO_MENTOR
  MENTOR_TO_QC
  QC_TO_MENTOR
  QC_TO_SUPER_ADMIN
}

enum SubmissionDecision {
  PENDING
  APPROVE
  REQUEST_CHANGES
  /// Mentor advisory OK — does not set step to APPROVED (only QC APPROVE does).
  ENDORSE
}

/// Hunter workspace: 8 wizard steps until super-admin publishes the draft.
model ReportDraft {
  id              String                     @id @default(uuid())
  hunterId        String                     @map("hunter_id")
  /// Squad member allowed to edit the draft and submit workflow steps (defaults to `hunter_id`).
  hunterWriterId  String                     @map("hunter_writer_id")
  version         Int                        @default(1)
  aggregateStatus ReportDraftAggregateStatus @default(DRAFT) @map("aggregate_status")
  /// Set when super-admin requests a global revision (team-wide rework).
  superAdminRevisionRequestedAt DateTime? @map("super_admin_revision_requested_at")
  /// Incremented on each super-admin global revision request (never decremented).
  superAdminGlobalRevisionCount Int @default(0) @map("super_admin_global_revision_count")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  hunter        User              @relation("ReportDraftOwner", fields: [hunterId], references: [id], onDelete: Cascade)
  hunterWriter  User              @relation("ReportDraftHunterWriter", fields: [hunterWriterId], references: [id], onDelete: Cascade)
  steps             ReportDraftStep[]
  submissions       Submission[]
  globalSubmissions GlobalSubmission[]
  reportTeam        ReportTeam?

  @@index([hunterId])
  @@index([hunterWriterId])
  @@index([aggregateStatus])
  @@map("report_drafts")
}

model GlobalSubmission {
  id               String             @id @default(uuid())
  reportDraftId    String             @map("report_draft_id")
  revisionNumber   Int                @map("revision_number")
  payload          Json
  submittedAt      DateTime           @default(now()) @map("submitted_at")
  submittedBy      String             @map("submitted_by")
  reviewerRole     ReviewerRole       @map("reviewer_role")
  decision         SubmissionDecision @default(PENDING)
  decidedAt        DateTime?          @map("decided_at")
  decidedBy        String?            @map("decided_by")

  reportDraft      ReportDraft              @relation(fields: [reportDraftId], references: [id], onDelete: Cascade)
  reviewerComments GlobalReviewerComment[]

  @@unique([reportDraftId, revisionNumber, reviewerRole], map: "gs_draft_rev_role_uq")
  @@index([reportDraftId], map: "gs_report_draft_id_idx")
  @@index([reviewerRole, decision], map: "gs_reviewer_decision_idx")
  @@map("global_submissions")
}

model GlobalReviewerComment {
  id                 String       @id @default(uuid())
  globalSubmissionId String       @map("global_submission_id")
  authorId           String       @map("author_id")
  authorRole         ReviewerRole @map("author_role")
  anchor             Json?
  body               String
  createdAt          DateTime     @default(now()) @map("created_at")
  resolvedAt         DateTime?    @map("resolved_at")

  globalSubmission GlobalSubmission @relation(fields: [globalSubmissionId], references: [id], onDelete: Cascade)

  @@index([globalSubmissionId], map: "grc_global_submission_id_idx")
  @@map("global_reviewer_comments")
}

/// One row per wizard step (8 per draft). Submissions attach here, not on the draft root.
model ReportDraftStep {
  id                   String        @id @default(uuid())
  reportDraftId        String        @map("report_draft_id")
  step                 DraftStep
  payload              Json          @default("{}")
  status               StepStatus    @default(IN_PROGRESS)
  currentRound         Int           @default(0) @map("current_round")
  assignedReviewerRole ReviewerRole? @map("assigned_reviewer_role")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  reportDraft ReportDraft             @relation(fields: [reportDraftId], references: [id], onDelete: Cascade)
  attachments ReportDraftAttachment[]
  submissions Submission[]

  @@unique([reportDraftId, step])
  @@index([reportDraftId])
  @@map("report_draft_steps")
}

/// Live binary assets on a step (upload wired later).
model ReportDraftAttachment {
  id                String   @id @default(uuid())
  reportDraftStepId String   @map("report_draft_step_id")
  filename          String
  mimeType          String   @map("mime_type")
  sizeBytes         Int      @map("size_bytes")
  storageKey        String   @map("storage_key")
  thumbnailUrl      String?  @map("thumbnail_url")
  uploadedBy        String   @map("uploaded_by")
  uploadedAt        DateTime @default(now()) @map("uploaded_at")

  reportDraftStep ReportDraftStep @relation(fields: [reportDraftStepId], references: [id], onDelete: Cascade)

  @@index([reportDraftStepId])
  @@map("report_draft_attachments")
}

/// Immutable review round; parent is the step. Denormalized draft/step for list queries.
model Submission {
  id                String             @id @default(uuid())
  reportDraftStepId String             @map("report_draft_step_id")
  reportDraftId     String             @map("report_draft_id")
  step              DraftStep
  round             Int
  submissionKind    SubmissionKind     @default(HUNTER_TO_REVIEWER) @map("submission_kind")
  payload           Json
  submittedAt       DateTime           @default(now()) @map("submitted_at")
  submittedBy       String             @map("submitted_by")
  reviewerRole      ReviewerRole       @map("reviewer_role")
  decision          SubmissionDecision @default(PENDING)
  decidedAt         DateTime?          @map("decided_at")
  decidedBy         String?            @map("decided_by")

  reportDraftStep     ReportDraftStep                @relation(fields: [reportDraftStepId], references: [id], onDelete: Cascade)
  reportDraft         ReportDraft                    @relation(fields: [reportDraftId], references: [id], onDelete: Cascade)
  reviewerComments    ReviewerComment[]
  attachmentSnapshots SubmissionAttachmentSnapshot[]
  contentSnapshots    SubmissionContentSnapshot[]

  @@unique([reportDraftStepId, round, reviewerRole, submissionKind])
  @@index([reportDraftId])
  @@index([reviewerRole, decision])
  @@map("submissions")
}

model ReviewerComment {
  id           String       @id @default(uuid())
  submissionId String       @map("submission_id")
  authorId     String       @map("author_id")
  authorRole   ReviewerRole @map("author_role")
  anchor       Json?
  body         String
  createdAt    DateTime     @default(now()) @map("created_at")
  resolvedAt   DateTime?    @map("resolved_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("reviewer_comments")
}

/// Frozen files at submit time (domain: attachmentsSnapshot).
model SubmissionAttachmentSnapshot {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  filename     String
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  storageKey   String   @map("storage_key")
  thumbnailUrl String?  @map("thumbnail_url")
  uploadedAt   DateTime @map("uploaded_at")
  uploadedBy   String   @map("uploaded_by")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_attachment_snapshots")
}

/// Optional payload history inside one submission (reserved for later).
model SubmissionContentSnapshot {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  payload      Json
  capturedAt   DateTime @default(now()) @map("captured_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_content_snapshots")
}

/// Workflow role on a report team (distinct from global `Role`).
enum ReportTeamMemberRole {
  HUNTER
  QUALITY_CHECKER
  MENTOR
}

enum ReportTeamJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Squad for one report draft (not org-wide teams).
model ReportTeam {
  id            String   @id @default(uuid())
  reportDraftId String   @unique @map("report_draft_id")
  label         String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  reportDraft  ReportDraft             @relation(fields: [reportDraftId], references: [id], onDelete: Cascade)
  members       ReportTeamMember[]
  joinRequests  ReportTeamJoinRequest[]
  leaveRequests ReportTeamLeaveRequest[]

  @@index([reportDraftId])
  @@map("report_draft_teams")
}

model ReportTeamMember {
  id       String               @id @default(uuid())
  teamId   String               @map("team_id")
  userId   String               @map("user_id")
  role     ReportTeamMemberRole
  joinedAt DateTime             @default(now()) @map("joined_at")

  team ReportTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("report_team_members")
}

/// User asks coordinator to join a team (or general pool when teamId is null).
model ReportTeamJoinRequest {
  id            String                      @id @default(uuid())
  teamId        String?                     @map("team_id")
  userId        String                      @map("user_id")
  requestedRole ReportTeamMemberRole        @map("requested_role")
  message       String?
  status        ReportTeamJoinRequestStatus @default(PENDING)
  requestedAt   DateTime                    @default(now()) @map("requested_at")
  decidedAt     DateTime?                   @map("decided_at")
  decidedById   String?                     @map("decided_by_id")

  team      ReportTeam? @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User       @relation("JoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User?      @relation("JoinRequestDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([userId, status])
  @@map("report_team_join_requests")
}

/// Primary hunter asks the coordinator to remove them from the squad (cannot self-leave while `hunter_id`).
model ReportTeamLeaveRequest {
  id          String                      @id @default(uuid())
  teamId      String                      @map("team_id")
  userId      String                      @map("user_id")
  message     String?
  status      ReportTeamJoinRequestStatus @default(PENDING)
  requestedAt DateTime                    @default(now()) @map("requested_at")
  decidedAt   DateTime?                   @map("decided_at")
  decidedById String?                     @map("decided_by_id")

  team      ReportTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User       @relation("LeaveRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User?      @relation("LeaveRequestDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([userId, status])
  @@map("report_team_leave_requests")
}

// ─── Quality criteria (RBAC QUALITY_CHECKER; independent of report-team roles) ───

enum QualityCriterionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model QualityCriterionCategory {
  id        String   @id @default(uuid())
  name      String
  color     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  criteria QualityCriterion[]

  @@map("quality_criterion_categories")
}

model QualityCriterionTargetType {
  id                String   @id @default(uuid())
  code              String   @unique
  label             String
  requiresTargetRef Boolean  @default(true) @map("requires_target_ref")
  sortOrder         Int      @default(0) @map("sort_order")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  criterionLinks QualityCriterionTargetTypeLink[]
  distributions  QualityCriterionDistribution[]

  @@map("quality_criterion_target_types")
}

model QualityCriterion {
  id              String                 @id @default(uuid())
  code            String                 @unique
  title           String
  explanation     String?                @db.Text
  status          QualityCriterionStatus @default(DRAFT)
  categoryId      String?                @map("category_id")
  createdByUserId String                 @map("created_by_user_id")
  publishedAt     DateTime?              @map("published_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  category        QualityCriterionCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy       User                             @relation("QualityCriterionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  targetTypeLinks QualityCriterionTargetTypeLink[]
  distributions   QualityCriterionDistribution[]

  @@index([status])
  @@index([createdByUserId])
  @@index([categoryId])
  @@map("quality_criteria")
}

model QualityCriterionTargetTypeLink {
  criterionId  String @map("criterion_id")
  targetTypeId String @map("target_type_id")

  criterion  QualityCriterion           @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  targetType QualityCriterionTargetType @relation(fields: [targetTypeId], references: [id], onDelete: Restrict)

  @@id([criterionId, targetTypeId])
  @@map("quality_criterion_target_type_links")
}

model QualityCriterionDistribution {
  id                  String   @id @default(uuid())
  criterionId         String   @map("criterion_id")
  targetTypeId        String   @map("target_type_id")
  targetRefId         String?  @map("target_ref_id")
  distributedByUserId String   @map("distributed_by_user_id")
  distributedAt       DateTime @default(now()) @map("distributed_at")

  criterion     QualityCriterion           @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  targetType    QualityCriterionTargetType @relation(fields: [targetTypeId], references: [id], onDelete: Restrict)
  distributedBy User                       @relation("QualityDistributionCreator", fields: [distributedByUserId], references: [id], onDelete: Restrict)
  checks        QualityCriterionCheck[]

  @@index([criterionId])
  @@index([targetTypeId, targetRefId])
  @@map("quality_criterion_distributions")
}

model QualityCriterionCheck {
  id              String    @id @default(uuid())
  distributionId  String    @map("distribution_id")
  context         String
  checked         Boolean   @default(false)
  checkedByUserId String?   @map("checked_by_user_id")
  checkedAt       DateTime? @map("checked_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  distribution QualityCriterionDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  checkedBy    User?                        @relation("QualityCheckUpdater", fields: [checkedByUserId], references: [id], onDelete: SetNull)

  @@unique([distributionId, context])
  @@index([distributionId])
  @@map("quality_criterion_checks")
}
