# API Bug Bounty — environnement Node
# Local / nx serve : development (valeur par défaut si absent).
# NODE_ENV en prod sans conteneur : passer à production sur le serveur. Dans une image construite depuis docker/Dockerfile (local/lab uniquement), NODE_ENV=production y est déjà fixé.
NODE_ENV=development

# Configuration base de données
# DATABASE_URL : alignée sur DATABASE_NAME et sur l’hôte qui exécute l’API (machine hôte vs conteneur « api »).
#
# --- PostgreSQL avec Prisma (`DATABASE_NAME=POSTGRESQL_PRISMA`)
# Schéma : `server/prisma/schema.prisma` — migrations : `server/prisma/migrations/`.
# server/docker/start.sh active le profil « pg » → postgres + pgweb (+ api) lorsque DATABASE_NAME=POSTGRESQL_PRISMA.
#
# --- MySQL avec Prisma (`DATABASE_NAME=MYSQL_PRISMA`)
# Schéma : `server/prisma/schema.mysql.prisma` — migrations : `server/prisma/migrations-mysql/`.
# Profil Docker « mysql » → mysql + Adminer (+ api). Générer le client : `DATABASE_NAME=MYSQL_PRISMA pnpm prisma:generate`.
# Ex. URL (hôte local) : mysql://bugbountyapp:bugbountyapp@localhost:3306/bugbountyapp
# Ex. URL (API dans Docker) : mysql://bugbountyapp:bugbountyapp@mysql:3306/bugbountyapp
# MYSQL_HOST_PORT=3306
# MYSQL_ROOT_PASSWORD=bugbountyapp
# MYSQL_DATABASE=bugbountyapp
# MYSQL_USER=bugbountyapp
# MYSQL_PASSWORD=bugbountyapp
# ADMINER_HOST_PORT=8088
# Défauts Compose (surcharge : POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, POSTGRES_HOST_PORT, PGWEB_HOST_PORT).
# PGWEB_HOST_PORT=8087   # port hôte pour ouvrir pgweb ; utilisé aussi dans les logs de démarrage de l’API (défaut 8087 si absent).
# API dans Docker : hôte du service = « postgres » (réseau Compose), pas localhost. Défauts bugbountyapp :
DATABASE_URL=postgres://bugbountyapp:bugbountyapp@localhost:5432/bugbountyapp
# API uniquement sur la machine (nx serve) + Postgres dans Docker (port 5432 exposé sur l’hôte) :
# DATABASE_URL=postgres://bugbountyapp:bugbountyapp@localhost:5432/bugbountyapp (dans le conteneur Docker : postgres://bugbountyapp:bugbountyapp@postgres:5432/bugbountyapp)
#
# --- api-watch + Prisma (résumé — guide : server/README.md section « PostgreSQL et Prisma », server/docker/README.md § Prisma)
# `pnpm docker:watch` → puis `pnpm docker:prisma:generate`, `docker:prisma:deploy`, puis données : `pnpm docker:prisma:seed`.
# Prisma sur l’hôte : `pnpm prisma generate`, `pnpm prisma migrate deploy`, `pnpm prisma:seed` (`prisma:seed-demo` = alias ; `pnpm prisma:seed:docker` si DATABASE_URL encore @postgres).
# Données (rôles + démo optionnelle) : pas dans les migrations — `prisma/seed/*.sql`. En prod : `SEED_DEMO_USER=false` recommandé.
# SEED_DEMO_USER=false
#
#
# --- MongoDB (alternative — DATABASE_NAME=MONGODB)
# nx serve + Mongo sur la machine : ex. mongodb://localhost:27017/bugbountyapi
# API dans Docker + profil « mongodb » (mongo-express sur 8086 par défaut) : hôte « mongodb », pas localhost
#   ex. mongodb://mongodb:27017/bugbountyapp (aligné avec MONGO_INITDB_DATABASE dans compose.dev.yaml)
#
# `IN-MEMORY` pour DATABASE_NAME : pas de conteneur de base Docker au démarrage (profils mongo/pg désactivés).
#
# AUTH_TYPE : désormais uniquement Passport JWT.
DATABASE_NAME=POSTGRESQL_PRISMA  # Options: POSTGRESQL_PRISMA | MYSQL_PRISMA | MONGODB | IN-MEMORY

# Configuration serveur
# PORT : port d’écoute du processus (dans l’image Docker : toujours 3000, voir section prod ci-dessous).
# API_HOST_PORT : port de l’API Bug Bounty sur l’hôte (Docker Compose dev/prod).
PORT=3000
GLOBAL_PREFIX=api

# CORS : origines exactes séparées par des virgules (sans chemin). Doit inclure l’URL du front Next (dossier client/)
# telle qu’affichée dans le navigateur (en dev : http://localhost:3001 — le port 3000 sert à l’API Nest, pas au Next du monorepo).
# Valeur par défaut dans le code : voir server/src/shared/cors.util.ts — surcharger ici si besoin.
CORS_ORIGIN=https://bugbountyapp.vercel.app,http://localhost:3001
# CORS_ORIGIN=*

# Configuration authentification
# PASSPORT_JWT : inscription / connexion e-mail+mot de passe via Passport + JWT.
AUTH_TYPE=PASSPORT_JWT
# À changer en production. Si quelqu’un obtient JWT_SECRET, il peut émettre des jetons valides (usurper n’importe quel compte). Même valeur que `JWT_SECRET` côté Next.
# Secret fort : préférer des octets aléatoires, pas une phrase mémorable — ex. `openssl rand -hex 32` (64 caractères hex, pratique dans .env) ou `openssl rand -base64 48` (mettre la valeur entre guillemets si elle contient +/=).
# HS256 : toute chaîne UTF-8 convient ; coller exactement le même secret sur https://jwt.io (HS256) uniquement pour déboguer — ne pas y mettre les vrais secrets de production.
JWT_SECRET=mon-lapin-caillousky-dans-la-serre
# Durée de vie du JWT d’accès (`jsonwebtoken` / `expiresIn`, ex. 15m, 1h). Si absent, le code utilise 10m par défaut — en prod, viser ≤15m pour l’accès et coupler avec le refresh / nouvelle connexion si besoin.
JWT_EXPIRES_IN=15m
#
# Jetons de refresh opaques : stockés hachés en base (`refresh_tokens` / collection Mongo `refresh_tokens`). TTL appliqué à la création des lignes.
# 30d = 30 jours ; 1h = 1 heure ; 10m = 10 minutes ; 30s = 30 secondes.
JWT_REFRESH_EXPIRES_IN=30d
# Nom du cookie httpOnly pour le refresh (Nest : `PassportJwtAuthController` login/register/refresh).
# JWT_REFRESH_COOKIE_NAME=refresh_token

# Libellé dans l’OTP (Google Authenticator) pour la démo TOTP — ignoré s’il n’y a pas de flux 2FA.
# TOTP_ISSUER=BugBountyApp
# Tolérance d’horloge (secondes) pour verify() otplib sur la démo TOTP.
# TOTP_EPOCH_TOLERANCE=30

# Obligatoire pour l’activation TOTP « réelle » (`POST /auth/totp/enable/*`) : passphrase longue (≥ 16 car.)
# utilisée avec scrypt pour chiffrer le secret en base (AES-256-GCM, préfixe `v1:` en DB).
# Générer en dev : openssl rand -hex 32  (puis gardez-la stable par environnement)
TOTP_ENCRYPTION_KEY=change-this-to-a-secret-at-least-16-chars
# ex. : b5172da27faa865d0fd6095ceda7d0f7c48019cd4f479ca32161e258efd246d8

# --- Mot de passe oublié (uniquement si DATABASE_NAME=POSTGRESQL_PRISMA) ---
# URL du front Next (sans slash final) pour construire le lien dans l’e-mail : {base}/{lng}/password-reset?token=…
CLIENT_PUBLIC_BASE_URL=http://localhost:3001
# Durée de validité du jeton opaque (ex. 15m, 1h). Défaut : 15m
# PASSWORD_RESET_TOKEN_TTL=15m
# Fournisseur d’e-mail transactionnel (un seul actif) : console | mailgun | brevo
MAIL_PROVIDER=console

# MAIL_FROM_EMAIL=noreply@votredomaine.com
# MAIL_FROM_NAME=BugBountyApp
# Clé API unique pour tout fournisseur qui l’exige (Brevo, SendGrid, clé API Mailgun, etc.) — ignorée avec MAIL_PROVIDER=console.
# MAIL_TRANSACTIONAL_API_KEY=
# --- Mailgun uniquement (en plus de la clé ci-dessus) : domaine d’envoi + région API ---
# MAILGUN_DOMAIN=
# MAILGUN_REGION=us

# --- BullMQ / file d’attente PDF (rapports) ---
# L’API se connecte à Redis au démarrage pour `POST /api/pdf/jobs` (génération asynchrone).
# Démarrer Redis + Redis Insight (UI) : depuis `server/docker/` :
#   docker compose -f compose.dev.yaml --profile redis up -d redis redisinsight
# Puis ouvrir Redis Insight : http://localhost:5540 (ou le port défini par REDIS_INSIGHT_HOST_PORT).
# Dans l’UI « Add database » : host `redis`, port `6379` (nom DNS du service Compose, pas localhost).
# Santé du conteneur Insight : http://localhost:5540/api/health/
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Port hôte → Redis (défaut 6379) si déjà pris sur la machine :
# REDIS_HOST_PORT=6380
# Port hôte → Redis Insight (défaut 5540) :
# REDIS_INSIGHT_HOST_PORT=5540
# Mot de passe Redis (laisser vide en dev si Redis sans auth) :
# REDIS_PASSWORD=

# Génération PDF (Puppeteer) :
# - IS_PUPETTEER_WITH_CHROMIUM=true => mode local : utilise le Chromium géré par Puppeteer (pas d'executablePath Docker forcé).
# - Laisser false/absent dans Docker/CI pour utiliser CHROMIUM_PATH ou PUPPETEER_EXECUTABLE_PATH.
IS_PUPETTEER_WITH_CHROMIUM=false
# En Docker, CHROMIUM_PATH est déjà défini dans l'image (voir docker/Dockerfile).
CHROMIUM_PATH=/usr/bin/chromium

# --- Stack Docker locale / lab (docker/compose.lab.yml), pas déploiement prod du projet ---
# MONGO_ROOT_PASSWORD=mot_de_passe_fort_pour_mongo
# Avec Postgres en prod (profil pg) : POSTGRES_PASSWORD=… (et optionnellement POSTGRES_USER, POSTGRES_DB).
#
# Deux variables de port (mappage Compose = « API_HOST_PORT:3000 » = hôte → conteneur) :
#   - API_HOST_PORT : port sur l’hôte pour l’API Bug Bounty (ex. 3003).
#   - PORT : le port *dans* le conteneur (doit rester 3000, sinon incompatibilité avec le compose).
# Copier-coller typique côte à côte :
# API_HOST_PORT=3003
# PORT=3000
#
# Mode Docker (POSTGRESQL_PRISMA ou MONGODB) : DATABASE_URL doit cibler le bon service Compose (« postgres » ou « mongodb »), pas localhost, depuis le conteneur api.
