# API Bug Bounty — environnement Node
# Local / nx serve : development (valeur par défaut si absent).
# Image Docker production : NODE_ENV=production est défini dans docker/Dockerfile (stage build + image finale).
NODE_ENV=development

# Configuration Base de Données
# Par défaut : nx serve ou Mongo sur ta machine (localhost) sinon adapter la valeur 
# Si usage de docker qui conteneurise mongo + api : mongodb://mongodb:27017/bugbountyapi).
DATABASE_URL=mongodb://localhost:27017/bugbountyapi
# Mongo express est disponible sur le port 8086 si usage de docker avec ces credentials : mongodb://admin:pass@localhost:27017/db?ssl=false
# MONGODB : docker/compose.dev.yaml peut démarrer MongoDB + mongo-express (profil « mongodb »).

# IN-MEMORY : pas de Mongo au démarrage (recommandé pour nx serve sans Docker).
# MONGODB : nécessite DATABASE_URL + Mongo joignable.
#
# Si DATABASE_NAME=MONGODB : AUTH_TYPE=JWT est en pratique obligatoire tant que tu n’as pas
# un projet Firebase (Admin SDK + comptes dans Firebase Authentication) configuré à distance.
# Sans Firebase opérationnel, AUTH_TYPE=FIREBASE n’expose pas l’inscription / connexion email-mot de passe
# vers Mongo (pas de POST /api/auth/register|login).
DATABASE_NAME=IN-MEMORY  # Options: MONGODB, FIREBASE, IN-MEMORY

# Configuration Serveur
# PORT = port d’écoute du process (dans l’image Docker : toujours 3000, voir section prod ci-dessous).
# API_HOST_PORT = port de l’API Bug Bounty sur l’hôte (Docker compose dev/prod).
PORT=3000
GLOBAL_PREFIX=api

# CORS : origines exactes séparées par des virgules (sans path).
# Exemple : déploiement front Vercel + Next.js en local.
# Mettre * pour tout autoriser (déconseillé en prod).
CORS_ORIGIN=https://bugbountyapp.vercel.app,http://localhost:3000
# CORS_ORIGIN=*

# Configuration Authentification
# JWT : inscription / connexion email-mot de passe (Mongo ou IN-MEMORY selon DATABASE_NAME).
# FIREBASE : tokens Firebase uniquement ; à réserver si Firebase Admin + Auth sont configurés (projet distant).
# Avec MONGODB sans Firebase prêt : garde AUTH_TYPE=JWT.
AUTH_TYPE=JWT  # Options: JWT, FIREBASE
JWT_SECRET=votre-cle-secrete-changez-en-production

# Firebase (uniquement si utilisation de Firebase)
# FIREBASE_KEY_PATH=src/assets/web-api-firebase-key.json

# E2E (Jest) — OPTIONNEL si AUTH_TYPE=JWT (défaut) : ne rien mettre, les tests passent sans.
# Requis seulement pour e2e avec AUTH_TYPE=FIREBASE (Identity Toolkit / inscription Firebase).
# Clé API Web = Firebase Console > Paramètres > Général. CI : secret E2E_FIREBASE_WEB_API_KEY
#E2E_FIREBASE_WEB_API_KEY=

# --- Production (docker/compose.prod.yml sur le VPS) ---
# MONGO_ROOT_PASSWORD=mot_de_passe_fort_pour_mongo
#
# Deux variables port (mapping compose = "API_HOST_PORT:3000" = hôte -> conteneur) :
#   - API_HOST_PORT : port sur l’hôte pour l’API Bug Bounty (ex. 3003).
#   - PORT                : le port *dans* le conteneur (doit rester 3000, sinon incompat. avec le compose).
# Copier-coller typique côte à côte :
# API_HOST_PORT=3003
# PORT=3000

