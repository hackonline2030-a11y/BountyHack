meta {
  name: List report drafts (hunter)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/report-drafts?hunterId={{hunterId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const list = res.body;
  if (Array.isArray(list) && list[0] && list[0].id) {
    bru.setEnvVar("draftId", list[0].id);
  }
}
