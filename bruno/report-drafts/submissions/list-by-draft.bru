meta {
  name: List submissions for draft
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/report-drafts/submissions?draftId={{draftId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const list = res.body;
  if (Array.isArray(list) && list[0] && list[0].id) {
    bru.setEnvVar("submissionId", list[0].id);
  }
}
